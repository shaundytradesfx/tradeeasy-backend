{
  "info": {
    "name": "TradeEasy API Collection",
    "description": "Comprehensive collection for TradeEasy sentiment analytics API. Includes authentication, sentiment analysis, search, watchlists, alerts, and real-time endpoints.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-authenticate if no token exists",
          "if (!pm.environment.get('jwt_token')) {",
          "    console.log('No JWT token found, attempting demo login...');",
          "    pm.sendRequest({",
          "        url: pm.environment.get('base_url') + '/api/auth/demo-login',",
          "        method: 'GET'",
          "    }, function (err, response) {",
          "        if (err) {",
          "            console.log('Demo login failed:', err);",
          "        } else {",
          "            const responseJson = response.json();",
          "            pm.environment.set('jwt_token', responseJson.access_token);",
          "            pm.environment.set('user_id', responseJson.user_id);",
          "            console.log('Demo login successful, token set');",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Demo Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has access token', function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('access_token');",
                  "    pm.expect(responseJson).to.have.property('user_id');",
                  "    ",
                  "    // Store token for future requests",
                  "    pm.environment.set('jwt_token', responseJson.access_token);",
                  "    pm.environment.set('user_id', responseJson.user_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/demo-login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "demo-login"]
            },
            "description": "Quick demo login for testing. Returns JWT token for authentication."
          }
        },
        {
          "name": "Standard Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
