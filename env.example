# TradeEasy Backend - Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
# For PostgreSQL, format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://tradeeasy:tradeeasy@localhost:5432/tradeeasy

# For development with Docker Compose
# DATABASE_URL=postgresql://tradeeasy:tradeeasy@db:5432/tradeeasy

# RSS Feed Sources (comma-separated list)
RSS_SOURCES=https://www.investing.com/rss/news_25.rss,https://www.cnbc.com/id/10000664/device/rss/rss.html,https://www.reuters.com/rssfeed/businessNews

# HuggingFace Configuration
HUGGINGFACE_TOKEN=your_huggingface_token_here

# API Security
SECRET_KEY=your_secret_key_for_jwt_tokens
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# CORS Configuration (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,https://tradeeasy-frontend.example.com

# Scheduler Configuration
RSS_FETCH_INTERVAL_MINUTES=60

# Feature Flags
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_WEBSOCKETS=true
ENABLE_HISTORICAL_DATA=true

# Caching Configuration
REDIS_URL=redis://localhost:6379/0

# Email Configuration (for alerts)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=alerts@tradeeasy.com

# Development Settings
DEBUG=false
TESTING=false
